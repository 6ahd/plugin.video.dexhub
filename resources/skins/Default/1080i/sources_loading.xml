                <align>left</align><aligny>center</aligny>
                <label>$INFO[Window.Property(current_provider)]</label>
            </control>
            <control type="image">
                <left>100</left><top>876</top><width>620</width><height>8</height>
                <texture colordiffuse="66312166">special://home/addons/plugin.video.dexhub/resources/media/black.png</texture>
            </control>
            <control type="progress">
                <left>100</left><top>876</top><width>620</width><height>8</height>
                <info>Window.Property(progress_pct)</info>
                <texturebg colordiffuse="00000000">special://home/addons/plugin.video.dexhub/resources/media/black.png</texturebg>
                <lefttexture colordiffuse="FF7C3AED">special://home/addons/plugin.video.dexhub/resources/media/black.png</lefttexture>
                <midtexture colordiffuse="FF7C3AED">special://home/addons/plugin.video.dexhub/resources/media/black.png</midtexture>
                <righttexture colordiffuse="FF7C3AED">special://home/addons/plugin.video.dexhub/resources/media/black.png</righttexture>
            </control>
            <control type="label">
                <left>100</left><top>892</top><width>660</width><height>26</height>
                <font>font10</font><textcolor>FF8C82AA</textcolor>
                <align>left</align><aligny>center</aligny>
                <label>$INFO[Window.Property(sub_status)]</label>
            </control>

            <control type="label">
                <left>820</left><top>760</top><width>200</width><height>150</height>
