            <control type="button" id="9001">
                <left>1280</left><top>760</top><width>540</width><height>80</height>
                <font>font14</font><textcolor>FFFFFFFF</textcolor><focusedcolor>FFFFFFFF</focusedcolor>
                <align>center</align><aligny>center</aligny>
                <texturenofocus border="0" colordiffuse="FF10B981">special://home/addons/plugin.video.dexhub/resources/media/black.png</texturenofocus>
                <texturefocus border="0" colordiffuse="FF34D399">special://home/addons/plugin.video.dexhub/resources/media/black.png</texturefocus>
                <label>$INFO[Window.Property(sufficient_label)]</label>
                <onclick>SendClick(9999,10)</onclick>
            </control>
            <control type="group">
                <visible>Control.HasFocus(9001)</visible>
                <control type="image"><left>1276</left><top>756</top><width>548</width><height>3</height><texture colordiffuse="FF34D399">special://home/addons/plugin.video.dexhub/resources/media/black.png</texture></control>
                <control type="image"><left>1276</left><top>841</top><width>548</width><height>3</height><texture colordiffuse="FF34D399">special://home/addons/plugin.video.dexhub/resources/media/black.png</texture></control>
                <control type="image"><left>1276</left><top>756</top><width>3</width><height>88</height><texture colordiffuse="FF34D399">special://home/addons/plugin.video.dexhub/resources/media/black.png</texture></control>
                <control type="image"><left>1821</left><top>756</top><width>3</width><height>88</height><texture colordiffuse="FF34D399">special://home/addons/plugin.video.dexhub/resources/media/black.png</texture></control>
            </control>

            <control type="button" id="9000">
                <left>1280</left><top>860</top><width>540</width><height>60</height>
                <font>font13</font><textcolor>FFC8B7E0</textcolor><focusedcolor>FFFFFFFF</focusedcolor>
                <align>center</align><aligny>center</aligny>
                <texturenofocus border="0" colordiffuse="FF1A1330">special://home/addons/plugin.video.dexhub/resources/media/black.png</texturenofocus>
                <texturefocus border="0" colordiffuse="FFDC2626">special://home/addons/plugin.video.dexhub/resources/media/black.png</texturefocus>
