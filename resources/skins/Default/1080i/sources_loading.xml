            </control>

            <control type="label">
                <left>100</left><top>1010</top><width>900</width><height>30</height>
                <font>font10</font><textcolor>FFB07CFF</textcolor>
                <align>left</align><aligny>center</aligny>
                <label>[B]$INFO[Window.Property(hint_line)][/B]</label>
            </control>
        </control>
    </controls>
</window>
