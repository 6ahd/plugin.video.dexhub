            <control type="group">
                <visible>Control.HasFocus(9000)</visible>
                <control type="image"><left>1276</left><top>856</top><width>548</width><height>3</height><texture colordiffuse="FFFCA5A5">special://home/addons/plugin.video.dexhub/resources/media/black.png</texture></control>
                <control type="image"><left>1276</left><top>921</top><width>548</width><height>3</height><texture colordiffuse="FFFCA5A5">special://home/addons/plugin.video.dexhub/resources/media/black.png</texture></control>
