<?xml version="1.0" encoding="UTF-8"?>
<!--
  Dex Hub Custom Select Dialog (v3.9.25)
  =====================================================================
  Drop-in replacement for xbmcgui.Dialog().select(). Brand-styled
  scrollable list with optional icon, badge, and subtitle per row.

  Control IDs
    100  title label                — setLabel()
    300  list control               — addItem() / getSelectedItem()
    301  empty-state label

  Each item in the list (ListItem) carries:
    label              row title
    label2             row subtitle / hint
    setProperty 'badge'  Right-side badge text (e.g. quality, status)
    setArt thumb / icon  Left-side icon

  Window properties
    dexhub.select.title  — title at top of dialog
    dexhub.select.result — index of selected row, '-1' on cancel

  Action: clicking a row stamps the index and closes.
-->
<window type="dialog">
  <defaultcontrol always="true">300</defaultcontrol>
  <zorder>15</zorder>
  <animation effect="fade" start="0" end="100" time="180">WindowOpen</animation>
  <animation effect="fade" start="100" end="0" time="120">WindowClose</animation>
  <onload>SetProperty(dexhub.select.result,-1,10000)</onload>
  <controls>

    <!-- Modal dim -->
    <control type="image">
      <left>0</left><top>0</top><width>1920</width><height>1080</height>
      <texture>dim_overlay.png</texture>
    </control>

    <!-- Centered card 980×720 -->
    <control type="group">
      <left>470</left><top>180</top>
      <animation effect="slide" start="0,60" end="0,0" time="280" tween="cubic" easing="out">WindowOpen</animation>

      <control type="image">
        <left>0</left><top>0</top><width>980</width><height>720</height>
        <texture border="32">glass_panel.png</texture>
      </control>

      <!-- Brand accent stripe -->
      <control type="image">
        <left>40</left><top>14</top><width>900</width><height>4</height>
        <texture>brand_stripe.png</texture>
      </control>

      <!-- Title — id 100 -->
      <control type="label" id="100">
        <left>40</left><top>40</top><width>900</width><height>40</height>
        <font>font24_title</font>
        <textcolor>FFFFFFFF</textcolor>
        <align>center</align>
        <label>$INFO[Window.Property(dexhub.select.title)]</label>
      </control>

      <!-- Empty-state label -->
      <control type="label" id="301">
        <visible>IsEmpty(Container(300).NumItems)</visible>
        <left>40</left><top>340</top><width>900</width><height>40</height>
        <font>font13</font>
        <textcolor>FFB07CFF</textcolor>
        <align>center</align>
        <label>$LOCALIZE[30156]</label>
      </control>

      <!-- The list — id 300 -->
      <control type="list" id="300">
        <left>30</left><top>110</top><width>920</width><height>570</height>
        <pagecontrol>0</pagecontrol>
        <scrolltime tween="cubic" easing="out">220</scrolltime>
        <itemlayout height="96">
          <!-- Row background (idle) -->
          <control type="image">
            <left>0</left><top>4</top><width>920</width><height>88</height>
            <texture border="12">row_idle.png</texture>
          </control>
          <!-- Icon -->
          <control type="image">
            <left>16</left><top>16</top><width>64</width><height>64</height>
            <aspectratio>keep</aspectratio>
            <texture>$INFO[ListItem.Icon]</texture>
          </control>
          <!-- Title -->
          <control type="label">
            <left>100</left><top>14</top><width>620</width><height>32</height>
            <font>font13_title</font>
            <textcolor>FFFFFFFF</textcolor>
            <align>left</align>
            <aligny>center</aligny>
            <label>$INFO[ListItem.Label]</label>
          </control>
          <!-- Subtitle -->
          <control type="label">
            <left>100</left><top>50</top><width>620</width><height>28</height>
            <font>font12</font>
            <textcolor>FF8E7DB3</textcolor>
            <align>left</align>
            <aligny>center</aligny>
            <label>$INFO[ListItem.Label2]</label>
          </control>
          <!-- Right-side badge (e.g. quality, status) -->
          <control type="label">
            <left>740</left><top>30</top><width>160</width><height>40</height>
            <font>font13_title</font>
            <textcolor>FF33D8F7</textcolor>
            <align>right</align>
            <aligny>center</aligny>
            <label>$INFO[ListItem.Property(badge)]</label>
          </control>
        </itemlayout>
        <focusedlayout height="96">
          <!-- Row background (focused) -->
          <control type="image">
            <left>0</left><top>4</top><width>920</width><height>88</height>
            <texture border="12">row_focus.png</texture>
            <animation effect="zoom" start="98" end="100" center="auto" time="160">Focus</animation>
          </control>
          <!-- Icon -->
          <control type="image">
            <left>16</left><top>16</top><width>64</width><height>64</height>
            <aspectratio>keep</aspectratio>
            <texture>$INFO[ListItem.Icon]</texture>
          </control>
          <!-- Title -->
          <control type="label">
            <left>100</left><top>14</top><width>620</width><height>32</height>
            <font>font13_title</font>
            <textcolor>FFFFFFFF</textcolor>
            <align>left</align>
            <aligny>center</aligny>
            <label>$INFO[ListItem.Label]</label>
          </control>
          <!-- Subtitle -->
          <control type="label">
            <left>100</left><top>50</top><width>620</width><height>28</height>
            <font>font12</font>
            <textcolor>FFE5DEFF</textcolor>
            <align>left</align>
            <aligny>center</aligny>
            <label>$INFO[ListItem.Label2]</label>
          </control>
          <!-- Right-side badge -->
          <control type="label">
            <left>740</left><top>30</top><width>160</width><height>40</height>
            <font>font13_title</font>
            <textcolor>FFFFFFFF</textcolor>
            <align>right</align>
            <aligny>center</aligny>
            <label>$INFO[ListItem.Property(badge)]</label>
          </control>
        </focusedlayout>
      </control>

    </control>
  </controls>
</window>
